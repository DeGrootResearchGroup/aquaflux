__pycache__/
*.py[cod]
*.egg-info/
*.egg
build/
dist/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# JAX / XLA
*.pb

# Editors / OS
.DS_Store
.idea/
.vscode/
